{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "effortLevel": "high",
  "theme": "auto",
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Bash(cargo *)",
      "Bash(cat *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(git *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(make *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(pwd)",
      "Bash(tail *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git push)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./secrets/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/find-node.sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "oh-my-claudecode@omc": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  }
}
