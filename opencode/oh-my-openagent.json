{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "ultrawork": {
        "model": "anthropic/claude-opus-4-6",
        "variant": "max"
      },
      "prompt_append": "Delegate heavily to hephaestus for implementation. Parallelize exploration."
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "prompt_append": "You are the primary implementation agent. Own the codebase. Explore, decide, execute. Use LSP and AST-grep aggressively.",
      "permission": {
        "edit": "allow",
        "bash": {
          "git": "allow",
          "test": "allow"
        }
      }
    },
    "prometheus": {
      "model": "openai/gpt-5.4-mini-fast",
      "prompt_append": "Keep plans concise. Focus on file structure and key decisions."
    },
    "oracle": {
      "model": "opencode/minimax-m2.7",
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.1-codex-mini"
    },
    "explore": {
      "model": "openai/gpt-5.1-codex-mini"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4"
    },
    "metis": {
      "model": "openai/gpt-5.4-fast",
      "prompt_append": "Critically evaluate plans. Identify gaps, risks, and improvements. Be thorough."
    },
    "momus": {
      "model": "opencode/minimax-m2.7",
      "prompt_append": "Focus on code quality, edge cases, and test coverage."
    },
    "atlas": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini"
    },
    "git-operator": {}
  },
  "categories": {
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-low": {
      "model": "opencode/minimax-m2.7"
    },
    "unspecified-high": {
      "model": "xai/grok-code-fast-1"
    },
    "visual-engineering": {
      "model": "xai/grok-4.20-0309-reasoning",
      "variant": "high"
    },
    "deep": {
      "model": "openai/gpt-5.4"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    }
  },
  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "anthropic": 5,
      "opencode": 15,
      "xai": 15
    }
  },
  "lsp": {
    "marksman-lsp": {
      "command": [
        "marksman"
      ],
      "extensions": [
        ".md"
      ]
    }
  },
  "hashline_edit": true,
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  }
}
