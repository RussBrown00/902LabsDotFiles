{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"enabled_providers": ["anthropic", "openai", "xai"],
	"plugin": ["opencode-with-claude", "oh-my-openagent@latest"],
	"provider": {
		"anthropic": {
			"options": {
				"baseURL": "http://127.0.0.1:3456",
				"apiKey": "dummy"
			},
			"models": {
				"claude-opus-4-8": {},
				"claude-opus-4-7": {},
				"claude-sonnet-4-6": {},
				"claude-opus-4-6": {}
			}
		}
	},
	"mcp": {
		"figma": {
			"type": "remote",
			"url": "http://127.0.0.1:3845/mcp",
			"_url": "https://mcp.figma.com/mcp",
			"enabled": true,
			"oauth": {}
		},
		"shortcut": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.shortcut.com/mcp"
		},
		"postmark-template-sync": {
			"enabled": true,
			"type": "local",
			"command": ["node", "/Users/rbrown/workspace/photivo-support/postmark-template-sync-mcp/index.js"],
			"environment": {
				"POSTMARK_SERVER_TOKEN": "b37ee499-0503-4cf2-9fe7-f12a9448cc96"
			}
		},
		"honeybadger": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"-e",
				"HONEYBADGER_PERSONAL_AUTH_TOKEN",
				"ghcr.io/honeybadger-io/honeybadger-mcp-server:latest"
			],
			"environment": {
				"HONEYBADGER_PERSONAL_AUTH_TOKEN": "qL_JtTVYYp2mRkd5xk1y"
			},
			"enabled": true
		}
	}
}
